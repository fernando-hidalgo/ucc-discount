{
  "manifest_version": 3,
  "name": "UCC Descuentos",
  "version": "1.0.0",
  "description": "Agenda de código de descuento para Unión Cine Ciudad (Metromar)",
  "browser_specific_settings": {
    "gecko": {
      "id": "ucc-discount-codes@mj047",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.compraentradas.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "UCC Descuentos",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png"
    }
  }
}
